      },
      {
        "label": "آمار اتصالات",
        "cmd": "docker exec nc_pgbouncer psql -h localhost -p 5432 -U pgbouncer -d pgbouncer -c 'SHOW STATS;'",
        "check": "بررسی max connections"
      },
      {
        "label": "لاگ‌های اخیر",
        "cmd": "docker logs nc_pgbouncer --tail 50",
        "check": "چک credentials"
      },
      {
        "label": "ری‌استارت",
        "cmd": "docker restart nc_pgbouncer",
        "check": null
      }
    ]
  },
  "nc_pg_primary": {
    "commands": [
      {
        "label": "وضعیت container",
        "cmd": "docker inspect nc_pg_primary --format='{{.State.Status}} | health: {{.State.Health.Status}}'",
        "check": "بررسی وضعیت container"
      },
      {
        "label": "آماده بودن DB",
        "cmd": "docker exec nc_pg_primary pg_isready -U nextcloud -d nextcloud",
        "check": "آماده بودن PostgreSQL"
      },
      {
        "label": "وضعیت replication",
        "cmd": "docker exec nc_pg_primary psql -U nextcloud -d nextcloud -c 'SELECT client_addr,state,sync_state FROM pg_stat_replication;'",
        "check": "بررسی replication"
      },
      {
        "label": "تعداد connections",
        "cmd": "docker exec nc_pg_primary psql -U nextcloud -d nextcloud -c 'SELECT count(*) FROM pg_stat_activity;'",
        "check": "بررسی connections"
      },
      {
        "label": "لاگ‌های اخیر",
        "cmd": "docker logs nc_pg_primary --tail 50",
        "check": "چک کردن disk space"
      },
      {
        "label": "ری‌استارت",
        "cmd": "docker restart nc_pg_primary",
        "check": null
      }
    ]
  },
  "nc_pg_replica1": {
    "commands": [
      {
        "label": "وضعیت container",
        "cmd": "docker inspect nc_pg_replica1 --format='{{.State.Status}}'",
        "check": "بررسی وضعیت container"
      },
      {
        "label": "وضعیت recovery",
        "cmd": "docker exec nc_pg_replica1 psql -U nextcloud -d nextcloud -tAc 'SELECT pg_is_in_recovery();'",
        "check": "چک کردن recovery mode"
      },
      {
        "label": "replication lag",
        "cmd": "docker exec nc_pg_replica1 psql -U nextcloud -d nextcloud -tAc 'SELECT now()-pg_last_xact_replay_timestamp() AS lag;'",
        "check": "بررسی replication lag"
      },
      {
        "label": "لاگ‌های اخیر",
        "cmd": "docker logs nc_pg_replica1 --tail 50",
        "check": "اتصال به primary"
      },
      {
        "label": "ری‌استارت",
        "cmd": "docker restart nc_pg_replica1",
        "check": null
      }
    ]
  },
