        "cmd": "docker exec nc_app1 php occ status",
        "check": "چک کردن Nextcloud config"
      },
      {
        "label": "اتصال DB",
        "cmd": "docker exec nc_app1 php occ db:add-missing-indices --dry-run",
        "check": "اتصال به PgBouncer"
      },
      {
        "label": "اتصال Redis",
        "cmd": "docker exec nc_app1 php occ config:system:get redis host",
