{
  "nc_nginx": {
    "commands": [
      {
        "label": "وضعیت container",
        "cmd": "docker inspect nc_nginx --format='{{.State.Status}} | health: {{.State.Health.Status}}'",
        "check": "بررسی وضعیت container"
      },
      {
        "label": "تست nginx config",
        "cmd": "docker exec nc_nginx nginx -t",
        "check": "تست config file"
      },
      {
        "label": "لاگ‌های اخیر",
        "cmd": "docker logs nc_nginx --tail 50",
        "check": "بررسی upstream app nodes"
      },
      {
        "label": "بررسی port 80/443",
        "cmd": "ss -tlnp | grep -E ':80|:443'",
        "check": "بررسی port 80/443"
      },
      {
        "label": "ری‌استارت",
        "cmd": "docker restart nc_nginx",
        "check": null
      }
    ]
  },
  "nc_app1": {
    "commands": [
      {
        "label": "وضعیت container",
