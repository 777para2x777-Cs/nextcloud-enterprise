  "nc_pgbouncer": {
    "commands": [
      {
        "label": "وضعیت container",
        "cmd": "docker inspect nc_pgbouncer --format='{{.State.Status}}'",
        "check": "بررسی وضعیت container"
      },
      {
        "label": "نمایش pool‌ها",
        "cmd": "docker exec nc_pgbouncer psql -h localhost -p 5432 -U pgbouncer -d pgbouncer -c 'SHOW POOLS;'",
